rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    match /news/{id} {
      allow read: if true;            // public
      allow create, update, delete: if request.auth != null; // any signed-in user
    }
    match /products/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /settings/{id} {
      allow read: if true;            // public (for banner display on frontend)
      allow create, update, delete: if request.auth != null; // admin only
    }
  }
}
