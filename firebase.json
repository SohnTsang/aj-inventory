{
  "hosting": {
    "public": "A&J",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.md",
      "**/*.sh"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|webp|avif|svg|woff|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=3600" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/company", "destination": "/company.html" },
      { "source": "/services", "destination": "/services.html" },
      { "source": "/news", "destination": "/news.html" },
      { "source": "/news/**", "destination": "/news-detail.html" },
      { "source": "/products", "destination": "/products.html" },
      { "source": "/products/**", "destination": "/product-detail.html" },
      { "source": "/index", "destination": "/index.html" },
      { "source": "**", "destination": "./" }
    ]
  },
  "firestore": { 
    "rules": "firestore.rules", 
    "indexes": "firestore.indexes.json" 
  },
  "storage": { 
    "rules": "storage.rules" 
  }
}